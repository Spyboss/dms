---
const screenshots = [
  {
    title: 'Dashboard',
    description: 'Sales, inventory, and pending actions at a glance.',
    placeholder: 'dashboard',
  },
  {
    title: 'Billing',
    description: 'Create bills and export PDFs with inventory integration.',
    placeholder: 'billing',
  },
  {
    title: 'Inventory',
    description: 'Track each unit. Real-time status and batch operations.',
    placeholder: 'inventory',
  },
  {
    title: 'Quotations',
    description: 'Multi-line quotes with discounts and insurance fields.',
    placeholder: 'quotations',
  },
];
---

<section id="screenshots" class="border-b border-border bg-muted py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">See it in action</h2>
      <p class="mt-4 text-lg text-text-secondary">Screenshots from the live application.</p>
    </div>
    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        screenshots.map((shot) => (
          <div class="group overflow-hidden rounded-xl border border-border bg-white shadow-sm transition-all hover:shadow-md">
            <div class="aspect-[16/10] bg-gradient-to-br from-slate-50 to-gray-100 p-8">
              <div class="flex h-full flex-col items-center justify-center rounded-lg border-2 border-dashed border-border text-center">
                <svg class="h-10 w-10 text-text-secondary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="mt-3 text-sm font-medium text-text-secondary/60">{shot.title} Screenshot</p>
                <p class="mt-1 text-xs text-text-secondary/40">Replace with actual screenshot</p>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-semibold">{shot.title}</h3>
              <p class="mt-1 text-sm text-text-secondary">{shot.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
