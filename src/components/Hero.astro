---
---

<section class="relative overflow-hidden border-b border-border">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-surface to-accent-50" />
  <div class="relative mx-auto max-w-6xl px-6 pb-24 pt-20 md:pb-32 md:pt-28">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700">
          <span class="h-2 w-2 rounded-full bg-brand-500" />
          Built for Sri Lankan dealerships
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl" style="font-family: var(--font-display)">
          Dealership management software<br />
          <span class="text-brand-600">that replaces spreadsheets</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-text-secondary md:text-xl">
          Billing, inventory, quotations, and warranty claims in one place.
        </p>
        <div class="mt-8 flex items-center gap-6">
          <div class="flex items-center gap-3">
            <div class="rounded-lg border border-red-200 bg-red-50 px-3 py-2">
              <div class="text-xs font-medium text-red-600">Paper</div>
              <div class="text-lg font-bold text-red-500 line-through" style="font-family: var(--font-display)">25 min</div>
            </div>
            <svg class="h-5 w-5 text-text-secondary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <div class="rounded-lg border border-green-200 bg-green-50 px-3 py-2">
              <div class="text-xs font-medium text-green-600">DMS</div>
              <div class="text-lg font-bold text-green-600" style="font-family: var(--font-display)">5 min</div>
            </div>
          </div>
          <div class="hidden text-xs text-text-secondary/60 sm:block">per invoice</div>
        </div>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#contact" class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-brand-700 hover:shadow-md">
            Request a Demo
          </a>
          <a href="#features" class="inline-flex items-center justify-center rounded-lg border border-border px-8 py-3.5 text-base font-semibold text-text transition-all hover:bg-muted">
            Explore Features
          </a>
        </div>
        <div class="mt-8 flex items-center gap-6 text-sm text-text-secondary">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Production since 2025
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            2 dealerships live
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Encrypted by default
          </span>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/3] overflow-hidden rounded-xl border border-border bg-white shadow-xl">
          <img src="/screenshots/hero-dashboard.png" alt="TMR Dashboard" class="h-full w-full object-cover object-top" />
        </div>
        <div class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-xl border border-accent-200 bg-accent-50/50" />
      </div>
    </div>
  </div>
</section>
