---
const rows = [
  {
    question: 'When can we start?',
    spreadsheet: 'Today',
    traditional: 'In 2 to 6 months',
    uhadev: 'This week',
  },
  {
    question: 'What hardware do we need?',
    spreadsheet: 'Just a printer',
    traditional: 'Servers, Windows licenses, networking gear',
    uhadev: 'Nothing new. A browser and internet.',
  },
  {
    question: 'Can we use it on phones?',
    spreadsheet: 'No',
    traditional: 'Through a VPN',
    uhadev: 'Yes. Any device.',
  },
  {
    question: 'Who maintains the system?',
    spreadsheet: 'Your team manages files',
    traditional: 'You need dedicated IT staff',
    uhadev: 'We handle everything',
  },
  {
    question: 'How long to train staff?',
    spreadsheet: 'No training needed',
    traditional: 'Weeks of classroom training',
    uhadev: 'A few hours',
  },
  {
    question: 'Can staff work from home?',
    spreadsheet: 'In office only',
    traditional: 'Through a VPN',
    uhadev: 'From anywhere with internet',
  },
  {
    question: 'How does data backup work?',
    spreadsheet: 'You lose records if files are damaged',
    traditional: 'You manage your own backups',
    uhadev: 'Encrypted cloud database, managed for you',
  },
];
---

<section id="comparison" class="border-b border-border bg-muted/50 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">Spreadsheets, traditional DMS, or UHADEV</h2>
      <p class="mt-4 text-lg text-text-secondary">Pick your approach.</p>
    </div>

    <div class="mt-12 hidden grid-cols-4 gap-4 md:grid">
      <div class="col-span-1" />
      <div class="rounded-t-xl border border-border bg-white px-4 py-4 text-center text-sm font-semibold text-text-secondary">Spreadsheets</div>
      <div class="rounded-t-xl border border-border bg-white px-4 py-4 text-center text-sm font-semibold text-text-secondary">Traditional DMS</div>
      <div class="rounded-t-xl border-2 border-brand-400 bg-brand-50 px-4 py-4 text-center text-sm font-semibold text-brand-700">UHADEV DMS</div>

      {
        rows.map((row) => (
          <>
            <div class="flex items-center border-b border-border py-4 text-sm font-medium text-text">{row.question}</div>
            <div class="flex items-center border-b border-border bg-white px-4 py-4 text-sm text-text-secondary">{row.spreadsheet}</div>
            <div class="flex items-center border-b border-border bg-white px-4 py-4 text-sm text-text-secondary">{row.traditional}</div>
            <div class="flex items-center border-b border-brand-200 bg-brand-50/50 px-4 py-4 text-sm font-medium text-brand-800">{row.uhadev}</div>
          </>
        ))
      }
    </div>

    <div class="mt-12 space-y-4 md:hidden">
      {
        rows.map((row) => (
          <details class="group rounded-xl border border-border bg-white">
            <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-semibold text-text">
              {row.question}
              <svg class="h-4 w-4 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="space-y-2 border-t border-border px-5 pb-4 pt-3">
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-secondary">Spreadsheets</span>
                <span class="font-medium text-text-secondary">{row.spreadsheet}</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-text-secondary">Traditional DMS</span>
                <span class="font-medium text-text-secondary">{row.traditional}</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="font-semibold text-brand-700">UHADEV</span>
                <span class="font-medium text-brand-800">{row.uhadev}</span>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
