---
const categories = [
  {
    label: 'Frontend',
    items: ['React 18', 'TypeScript', 'Vite', 'Ant Design', 'Tailwind CSS'],
  },
  {
    label: 'Backend',
    items: ['Node.js', 'Express', 'TypeScript', 'Mongoose', 'Redis'],
  },
  {
    label: 'Database',
    items: ['MongoDB Atlas', 'Redis Cloud'],
  },
  {
    label: 'Infrastructure',
    items: ['Cloudflare Pages', 'Railway', 'Docker'],
  },
];
---

<section id="tech" class="border-b border-border bg-muted/50 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Built on modern infrastructure</h2>
      <p class="mt-4 text-lg text-text-secondary">Enterprise-grade stack that scales with your business.</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        categories.map((cat) => (
          <div class="rounded-xl border border-border bg-white p-6">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-brand-600">{cat.label}</h3>
            <ul class="mt-4 space-y-2">
              {
                cat.items.map((item) => (
                  <li class="flex items-center gap-2 text-sm text-text-secondary">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-400" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
