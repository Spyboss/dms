---
const faqs = [
  {
    question: 'Do you need to install anything?',
    answer: 'No. Open a browser, log in, and start working. It runs on any device with an internet connection.',
  },
  {
    question: 'How secure is customer data?',
    answer: 'We encrypt NIC numbers, addresses, and pricing data at rest using AES-256. Role-based access controls who sees what. Every change is logged.',
  },
  {
    question: 'Does it work on mobile?',
    answer: 'Yes. The interface works in any mobile browser. Sales staff can check inventory, create quotes, and view reports from the lot.',
  },
  {
    question: 'Can we run multiple locations on one system?',
    answer: 'Yes. Gunawardana Motors runs two locations on a single instance. Both sites share the same inventory, customer records, and reporting.',
  },
  {
    question: 'How fast can we get started?',
    answer: 'Most dealerships are up and running within a week. We handle data migration from spreadsheets or existing systems.',
  },
  {
    question: 'How is this different from a traditional DMS?',
    answer: 'Traditional systems run on local servers, require VPN access, and need IT support for updates. Ours runs in a browser. No installation, automatic updates, access from anywhere. Lower upfront cost and no IT staff needed.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`} />

<section id="faq" class="border-b border-border py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">Common questions from dealership owners</h2>
    </div>
    <div class="mx-auto mt-12 max-w-3xl divide-y divide-border">
      {
        faqs.map((faq) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-text">
              {faq.question}
              <svg class="h-5 w-5 shrink-0 text-text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 leading-relaxed text-text-secondary">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
