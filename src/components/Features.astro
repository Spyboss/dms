---
const features = [
  {
    title: 'Billing & Invoicing',
    description: 'Create invoices with cash, leasing, or advance payment. Encrypt customer data. Convert advances to final invoices. Export branded PDFs.',
    icon: 'invoice',
  },
  {
    title: 'Inventory Management',
    description: 'Track every unit from arrival to sale. Stock status: available, reserved, sold, or damaged.',
    icon: 'inventory',
  },
  {
    title: 'Quotations',
    description: 'Build multi-line quotes with insurance and discounts. Turn them into invoices in one click. Print branded PDFs.',
    icon: 'quotation',
  },
  {
    title: 'Warranty Processing',
    description: 'Submit digital warranty claims with auto-numbering. Generate bilingual PDFs in Sinhala and English. Track parts and approvals.',
    icon: 'warranty',
  },
  {
    title: 'Security & Access Control',
    description: 'We encrypt NIC numbers and addresses at rest. Set role-based permissions. Every change is logged with before and after values.',
    icon: 'security',
  },
  {
    title: 'Reports',
    description: 'View daily sales, outstanding balances, stock positions, and revenue by model. Run inventory aging reports with projections.',
    icon: 'reports',
  },
];

const iconMap = {
  invoice: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  inventory: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  quotation: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  warranty: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  security: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  reports: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---

<section id="features" class="border-b border-border py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">Tools for every part of your dealership</h2>
      <p class="mt-4 text-lg text-text-secondary">Sales floor, service, and back office. One system.</p>
    </div>
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div class="group rounded-xl border border-border bg-white p-6 transition-all hover:border-brand-200 hover:shadow-sm">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-100">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[feature.icon]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
